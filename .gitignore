# ============================================================
# NoetherSolve .gitignore
#
# POLICY: Only the tool source code and materials supporting
# papers on arXiv are public. Everything else stays local
# until a paper is submitted. This keeps the repo a menu
# (what the tool does) not a buffet (every finding).
#
# To make something public: submit the paper to arXiv first,
# then remove the specific gitignore line.
# ============================================================

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
*.egg

# === Secrets ===
.env
*.key

# === macOS / IDE ===
.DS_Store
.vscode/
.idea/
*.swp
.ipynb_checkpoints/
*.ipynb
nohup.out

# ============================================================
# UNPUBLISHED RESEARCH — gitignore until paper is on arXiv
# ============================================================

# --- All paper drafts, figures, submissions ---
paper/
figures/

# --- All experimental results ---
# (Specific numbers belong in papers, not in the repo)
results/

# --- Steering bank (440 files, ~13K facts from HuggingFace benchmarks) ---
# Regenerate with: python experiments/build_steering_bank.py
steering_bank/

# --- Steering vectors (model-specific, regenerate locally) ---
steering_vectors/

# --- Adapter weights (large binaries, train locally) ---
adapters/
router_state.npz

# --- Training data (generated from fact files) ---
training/

# --- Research scripts (one-off investigations) ---
research/

# --- Experiment scripts (not part of the tool) ---
experiments/

# --- Lab infrastructure ---
labs/
monitors/

# --- Problem definitions (fact files for oracle) ---
# Keep problem YAMLs but not the fact JSONs (those have unpublished data)
problems/*.json
problems/*_facts*.json
problems/*_v2.json

# --- One-off scripts not part of the tool ---
oracle_wrapper.py
vortex_checker.py
conservation_checker.py
autonomy_loop.py
dashboard.py
run_teacher_student.py
run_haiku_benchmark.py
test_haiku_tools.py
oracle_gem_publishable_benchmark.py
benchmark_oracle_gem.py
ORACLE_GEM_DELIVERY.txt
claim.py
claims.json
download_27b.py
em_checker.py
noether_monitor.py

# --- Documentation that references unpublished results ---
ORACLE_METHODOLOGY.md
CONTRIBUTING.md
CLAUDE.md

# --- Problem fact data (unpublished research data) ---
# Keep .yaml (domain plugin structure) but not .json (actual facts)
problems/*.json

# --- Data caches ---
data/

# --- Scripts (internal tooling, not part of the package) ---
scripts/

# ============================================================
# PUBLIC — these stay tracked
# ============================================================
# noethersolve/          — tool source code (the product)
# tests/                 — test suite (validates the tools)
# pyproject.toml         — package metadata
# README.md              — describes what the tool does
# CHANGELOG.md           — release history (generic, no numbers)
# LICENSE                — MIT
# .mcp.json              — MCP server config
# .github/               — CI workflows
# requirements.txt       — dependencies
# problems/*.yaml        — domain plugin definitions (structure, not data)
# .claude/settings.json  — Claude Code config
# .env.example           — env var template
