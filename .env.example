# NoetherSolve Environment Variables
# Copy to .env and fill in your values

# Required for automatic Zenodo paper publication
# Without this, papers are generated locally but not uploaded
ZENODO_TOKEN=...

# HuggingFace cache (required if models are stored outside ~/.cache/huggingface)
# The 27B model downloads to this path via download_27b.py
HF_HOME=/Volumes/4TB SD/ml_cache/huggingface

# Generation model override (default: mlx-community/Qwen3.5-27B-4bit)
# NOETHER_GEN_MODEL=mlx-community/Qwen3.5-27B-4bit
